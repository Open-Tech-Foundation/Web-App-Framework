{
  "name": "web-app-framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/Open-Tech-Foundation/Web-App-Framework.git"
  },
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite playground",
    "build": "bun run build:web && vite build playground",
    "preview": "bun run website:build && wrangler dev",
    "website:dev": "vite website",
    "website:build": "bun run build:web && vite build website",
    "test": "bun test",
    "deploy": "bun run website:build && wrangler deploy",
    "build:web": "bun run --cwd packages/web build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vite-plugin": "^1.33.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "wrangler": "^4.84.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/helper-module-imports": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@preact/signals-core": "^1.14.1",
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "zod": "^4.3.6"
  }
}
