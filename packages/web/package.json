{
  "name": "@opentf/web",
  "version": "0.4.0",
  "description": "The core engine of the Web App Framework, including the zero-VDOM compiler and signal-based runtime.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./compiler": {
      "types": "./dist/compiler/babel-plugin.d.ts",
      "import": "./dist/compiler/babel-plugin.js",
      "require": "./dist/compiler/babel-plugin.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js",
      "require": "./dist/router/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@preact/signals-core": "^1.14.1",
    "@babel/core": "^7.29.0",
    "@babel/helper-module-imports": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
